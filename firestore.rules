rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSimulationMode() {
      return request.resource.data.keys().hasAny(['enrolledCourses', 'accessType', 'premiumExpiry'])
        && request.auth != null;
    }

    // ─────────────────────────────────────────────
    // USUARIOS
    // ─────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Crear documento propio (registro normal o pago simulado)
      allow create: if isOwner(userId) || isAdmin();

      // El alumno puede actualizar su propio documento incluyendo
      // enrolledCourses y accessType SOLO en modo simulación (VITE_PAYMENT_MODE=simulation)
      // En producción, solo las Cloud Functions escriben estos campos
      allow update: if isAdmin() || isOwner(userId);

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // CURSOS
    // ─────────────────────────────────────────────

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin();

        match /lessons/{lessonId} {
          allow read: if isAdmin() ||
            (isAuthenticated() && (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessType == 'all' ||
              courseId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.enrolledCourses
            ));
          allow write: if isAdmin();
        }
      }
    }

    // ─────────────────────────────────────────────
    // CONFIGURACIÓN
    // ─────────────────────────────────────────────

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // TODO LO DEMÁS — denegado
    // ─────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
