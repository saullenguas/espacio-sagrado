rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Devuelve el documento del usuario o null si no existe
    function userDoc(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data
        : null;
    }

    // Campos que el usuario NUNCA puede modificar directamente
    // (solo Cloud Functions o admin pueden tocarlos)
    function noSensitiveFieldsChanged() {
      let protectedFields = ['enrolledCourses', 'accessType', 'premiumExpiry', 'role'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedFields);
    }

    // ─────────────────────────────────────────────
    // USUARIOS
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Registro: el usuario puede crear su propio documento
      allow create: if isOwner(userId) || isAdmin();

      // El usuario puede actualizar su perfil PERO no campos sensibles
      // Solo el admin (o Cloud Functions con admin SDK) puede modificar
      // enrolledCourses, accessType, premiumExpiry, role
      allow update: if isAdmin()
                    || (isOwner(userId) && noSensitiveFieldsChanged());

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // CURSOS
    // ─────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin();

        match /lessons/{lessonId} {
          // Verifica acceso con protección contra documentos inexistentes
          allow read: if isAdmin() || (
            isAuthenticated() &&
            userDoc(request.auth.uid) != null && (
              userDoc(request.auth.uid).accessType == 'all' ||
              courseId in userDoc(request.auth.uid).enrolledCourses
            )
          );
          allow write: if isAdmin();
        }
      }
    }

    // ─────────────────────────────────────────────
    // CONFIGURACIÓN
    // ─────────────────────────────────────────────
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // TODO LO DEMÁS — denegado
    // ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}